{
  "name": "discord-when-bot",
  "main": "dist/index.js",
  "version": "0.1.0",
  "private": true,
  "description": "A Discord bot using Sapphire Framework that creates availability polls by date.",
  "license": "MIT",
  "engines": {
    "node": ">=20 <21"
  },
  "volta": {
    "node": "20.12.2"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "smoke:create": "tsx scripts/persist-create.ts",
    "smoke:load": "tsx scripts/persist-load.ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sapphire/decorators": "latest",
    "@sapphire/framework": "latest",
    "better-sqlite3": "^9.4.3",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.12",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^1.6.1",
    "c8": "^10.1.3",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.1"
  }
}
