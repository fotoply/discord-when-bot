{
  "name": "discord-when-bot",
  "main": "dist/index.js",
  "version": "0.1.0",
  "private": true,
  "description": "A Discord bot using Sapphire Framework that creates availability polls by date.",
  "license": "MIT",
  "engines": {
    "node": ">=20 <21"
  },
  "volta": {
    "node": "20.12.2"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p . --noEmit",
    "smoke:create": "tsx scripts/persist-create.ts",
    "smoke:load": "tsx scripts/persist-load.ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run"
  },
  "dependencies": {
    "@sapphire/decorators": "^6.2.0",
    "@sapphire/framework": "^5.3.6",
    "better-sqlite3": "^12.2.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.2"
  },
  "optionalDependencies": {
    "canvas": "^3.2.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.1.1",
    "@stryker-mutator/typescript": "^4.0.0",
    "@stryker-mutator/vitest-runner": "^9.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.12",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "c8": "^10.1.3",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
